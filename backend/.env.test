# Test-only environment.
#
# @medusajs/test-utils (via pg-god) reads DB_USERNAME/DB_PASSWORD/DB_HOST/DB_PORT
# to CREATE and DROP the throwaway integration test database. Unlike the app's
# runtime connection, that path does NOT parse DATABASE_URL, and it defaults the
# username to the OS user when DB_USERNAME is unset. Setting it here lets
# `npm run test:integration:http` connect to the local Postgres super-user.
#
# DATABASE_URL is intentionally NOT set here so the app still uses the value
# from .env; dotenv loads .env.test first and .env fills the remaining keys.
DB_USERNAME=postgres
DB_HOST=localhost
DB_PORT=5432
