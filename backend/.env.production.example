# =============================================================================
# Medusa backend — PRODUCTION environment (Railway)
# =============================================================================
# Copy the KEYS (not this file) into Railway → your backend service → Variables.
# NEVER commit real secret values. This file only documents the required keys.
# =============================================================================

# -----------------------------------------------------------------------------
# Provided automatically by Railway plugins — DO NOT set these by hand.
# -----------------------------------------------------------------------------
# DATABASE_URL is injected by the Railway PostgreSQL plugin.
# Reference it in the backend service as: ${{Postgres.DATABASE_URL}}
DATABASE_URL=

# REDIS_URL is injected by the Railway Redis plugin. REQUIRED in production —
# when set, medusa-config.ts enables the Redis-backed event bus, cache,
# workflow engine and distributed locking. Without it Medusa falls back to
# in-memory (single-instance only, NOT safe for production).
# Reference it in the backend service as: ${{Redis.REDIS_URL}}
REDIS_URL=

# -----------------------------------------------------------------------------
# Secrets — generate strong, unique random values (e.g. `openssl rand -base64 32`)
# -----------------------------------------------------------------------------
# Signs auth/session JWTs. Must be a long random string. Changing it invalidates
# all existing sessions.
JWT_SECRET=

# Signs cookies. Must be a long random string, different from JWT_SECRET.
COOKIE_SECRET=

# Optional: encryption key for admin MFA secrets (32-byte base64). Only needed
# if you enable multi-factor auth for the admin dashboard.
AUTH_MFA_ENCRYPTION_KEY=

# -----------------------------------------------------------------------------
# CORS — comma-separated origins. MUST include the production URLs.
# -----------------------------------------------------------------------------
# Storefront origin(s) allowed to call the Store API. Use your Vercel URL.
# e.g. https://your-storefront.vercel.app
STORE_CORS=

# Admin dashboard origin(s). The admin is served by the backend itself, so use
# the Railway public backend URL. e.g. https://your-backend.up.railway.app
ADMIN_CORS=

# Origins allowed to hit the auth routes. Include BOTH the storefront and the
# admin/backend URLs, comma-separated.
# e.g. https://your-storefront.vercel.app,https://your-backend.up.railway.app
AUTH_CORS=

# -----------------------------------------------------------------------------
# Stripe — real keys required for live checkout.
# -----------------------------------------------------------------------------
# Secret key. Use sk_test_... while testing, sk_live_... in production.
STRIPE_API_KEY=

# -----------------------------------------------------------------------------
# Resend — transactional email.
# -----------------------------------------------------------------------------
# Resend API key (re_...).
RESEND_API_KEY=

# Verified sender address, e.g. orders@yourdomain.com
RESEND_FROM_EMAIL=

# -----------------------------------------------------------------------------
# Optional runtime tuning
# -----------------------------------------------------------------------------
# Worker mode: "shared" (default; one service handles API + background jobs),
# "server" (HTTP only) or "worker" (background jobs only). Only set this if you
# split the backend into separate Railway services. Leave unset for a single
# combined service.
# MEDUSA_WORKER_MODE=shared

# PORT is injected by Railway; Medusa binds to it automatically. Do not hardcode.
# PORT=9000

# Node environment — set to production on Railway.
NODE_ENV=production
