# =============================================================================
# Medusa backend — PRODUCTION environment (Render)
# =============================================================================
# Most keys are wired automatically by the Render Blueprint (render.yaml).
# The `sync: false` ones you set in Render → service → Environment.
# NEVER commit real secret values. This file only documents the required keys.
# =============================================================================

# -----------------------------------------------------------------------------
# Provided automatically by the Render Blueprint — DO NOT set these by hand.
# -----------------------------------------------------------------------------
# DATABASE_URL is injected from the managed Render Postgres (opl-postgres) via
# `fromDatabase` in render.yaml.
DATABASE_URL=

# REDIS_URL is injected from the managed Render Key-Value/Redis (opl-redis) via
# `fromService` in render.yaml. REQUIRED in production — when set,
# medusa-config.ts enables the Redis-backed event bus, cache, workflow engine
# and distributed locking. Without it Medusa falls back to in-memory
# (single-instance only, NOT safe for production).
REDIS_URL=

# -----------------------------------------------------------------------------
# Secrets — generate strong, unique random values (e.g. `openssl rand -base64 32`)
# -----------------------------------------------------------------------------
# Signs auth/session JWTs. Must be a long random string. Changing it invalidates
# all existing sessions.
JWT_SECRET=

# Signs cookies. Must be a long random string, different from JWT_SECRET.
COOKIE_SECRET=

# Optional: encryption key for admin MFA secrets (32-byte base64). Only needed
# if you enable multi-factor auth for the admin dashboard.
AUTH_MFA_ENCRYPTION_KEY=

# -----------------------------------------------------------------------------
# CORS — comma-separated origins. MUST include the production URLs.
# -----------------------------------------------------------------------------
# Storefront origin(s) allowed to call the Store API. Use your Vercel URL.
# e.g. https://your-storefront.vercel.app
STORE_CORS=

# Admin dashboard origin(s). The admin is served by the backend itself, so use
# the Render public backend URL. e.g. https://opl-backend.onrender.com
ADMIN_CORS=

# Origins allowed to hit the auth routes. Include BOTH the storefront and the
# admin/backend URLs, comma-separated.
# e.g. https://your-storefront.vercel.app,https://opl-backend.onrender.com
AUTH_CORS=

# -----------------------------------------------------------------------------
# Stripe — real keys required for live checkout.
# -----------------------------------------------------------------------------
# Secret key. Use sk_test_... while testing, sk_live_... in production.
STRIPE_API_KEY=

# -----------------------------------------------------------------------------
# Resend — transactional email.
# -----------------------------------------------------------------------------
# Resend API key (re_...).
RESEND_API_KEY=

# Verified sender address, e.g. orders@yourdomain.com
RESEND_FROM_EMAIL=

# -----------------------------------------------------------------------------
# Optional runtime tuning
# -----------------------------------------------------------------------------
# Worker mode: "shared" (default; one service handles API + background jobs),
# "server" (HTTP only) or "worker" (background jobs only). Only set this if you
# split the backend into separate Render services. Leave unset for a single
# combined service.
# MEDUSA_WORKER_MODE=shared

# PORT is injected by Render; Medusa binds to it automatically. Do not hardcode.
# PORT=9000

# Node environment — set to production on Render (render.yaml pins this).
NODE_ENV=production
