# =============================================================================
# Next.js storefront — PRODUCTION environment (Vercel)
# =============================================================================
# Copy the KEYS (not real values) into Vercel → Project → Settings →
# Environment Variables (Production). NEVER commit real secret values.
# =============================================================================

# -----------------------------------------------------------------------------
# Backend connection
# -----------------------------------------------------------------------------
# Server-side URL of the Medusa backend on Railway. NOT prefixed NEXT_PUBLIC_.
# Use the public Railway backend URL. e.g. https://your-backend.up.railway.app
MEDUSA_BACKEND_URL=

# Optional public copy of the backend URL (kept for tooling/docs compatibility).
NEXT_PUBLIC_MEDUSA_BACKEND_URL=

# Publishable API key from the Medusa sales channel (pk_...). Grab it from the
# backend logs after seeding, or from Admin → Settings → Publishable API Keys.
NEXT_PUBLIC_MEDUSA_PUBLISHABLE_KEY=

# -----------------------------------------------------------------------------
# Storefront config
# -----------------------------------------------------------------------------
# Default region, ISO-2 lowercase. This store defaults to Australia.
NEXT_PUBLIC_DEFAULT_REGION=au

# Public URL of the storefront itself. Use your Vercel production URL.
# e.g. https://your-storefront.vercel.app
NEXT_PUBLIC_BASE_URL=

# Secret used to authorize Next.js on-demand revalidation requests.
# Generate a strong random value (e.g. `openssl rand -base64 32`).
REVALIDATE_SECRET=

# -----------------------------------------------------------------------------
# Stripe (client-side) — required for the checkout payment UI to render.
# -----------------------------------------------------------------------------
# Stripe PUBLISHABLE key (pk_test_... or pk_live_...). This is the browser key,
# NOT the secret key. Must correspond to the same Stripe account whose SECRET
# key (STRIPE_API_KEY) is configured on the backend.
NEXT_PUBLIC_STRIPE_KEY=

# Optional Medusa-managed payments (only if you use Medusa Payments instead of a
# direct Stripe account). Leave blank when using the Stripe provider directly.
NEXT_PUBLIC_MEDUSA_PAYMENTS_PUBLISHABLE_KEY=
NEXT_PUBLIC_MEDUSA_PAYMENTS_ACCOUNT_ID=

# -----------------------------------------------------------------------------
# Optional: Medusa Cloud S3 image optimization (only for Medusa Cloud hosting).
# -----------------------------------------------------------------------------
MEDUSA_CLOUD_S3_HOSTNAME=
MEDUSA_CLOUD_S3_PATHNAME=
